{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "dev:pwa:lan": "vite --host 0.0.0.0 --mode pwa",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
