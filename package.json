{
  "name": "point",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:all": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:migrate": "node scripts/run-python.mjs -m alembic upgrade head",
    "db:seed": "node scripts/run-python.mjs -m app.seed",
    "setup:db": "npm run db:up && npm run db:migrate && npm run db:seed",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}

